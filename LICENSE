#!/usr/bin/env python3
"""Static polarization-of-light simulator and plot generator."""
from __future__ import annotations
import argparse
from pathlib import Path
from typing import Tuple
import matplotlib.pyplot as plt
import numpy as np

def polarization_components(ax: float = 1.0, ay: float = 1.0, phase_deg: float = 90.0, n_samples: int = 1200) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
    if ax < 0 or ay < 0:
        raise ValueError("Amplitudes must be non-negative.")
    if n_samples < 16:
        raise ValueError("n_samples must be at least 16.")
    phi = np.linspace(0.0, 2.0 * np.pi, n_samples)
    delta = np.deg2rad(phase_deg)
    ex = ax * np.cos(phi)
    ey = ay * np.cos(phi + delta)
    return phi, ex, ey

def stokes_parameters(ax: float, ay: float, phase_deg: float) -> Tuple[float, float, float, float]:
    delta = np.deg2rad(phase_deg)
    S0 = ax**2 + ay**2
    if S0 == 0:
        return 0.0, 0.0, 0.0, 0.0
    S1 = ax**2 - ay**2
    S2 = 2.0 * ax * ay * np.cos(delta)
    S3 = 2.0 * ax * ay * np.sin(delta)
    return S0, S1 / S0, S2 / S0, S3 / S0

def classify_state(ax: float, ay: float, phase_deg: float) -> Tuple[str, str, float, float]:
    S0, s1, s2, s3 = stokes_parameters(ax, ay, phase_deg)
    if S0 == 0:
        return "Zero field", "—", 0.0, 0.0
    psi = 0.5 * np.rad2deg(np.arctan2(s2, s1))
    chi = 0.5 * np.rad2deg(np.arcsin(np.clip(s3, -1.0, 1.0)))
    delta = np.deg2rad(phase_deg)
    near_linear = abs(np.sin(delta)) < 0.045 or ax < 0.02 or ay < 0.02
    near_circular = abs(ax - ay) < 0.04 and abs(abs(phase_deg) - 90.0) < 4.0
    if near_linear:
        return "Linear", "None", psi, chi
    if near_circular:
        handed = "Left-handed" if s3 > 0 else "Right-handed"
        return "Circular", handed, psi, chi
    handed = "Left-handed" if s3 > 0 else "Right-handed"
    return "Elliptical", handed, psi, chi

def make_plots(ax: float = 1.0, ay: float = 1.0, phase_deg: float = 90.0, save_prefix: Path | None = None, show: bool = False) -> None:
    phi, ex, ey = polarization_components(ax=ax, ay=ay, phase_deg=phase_deg)
    _, s1, s2, s3 = stokes_parameters(ax, ay, phase_deg)
    label, handed, psi, chi = classify_state(ax, ay, phase_deg)
    max_a = max(ax, ay, 1e-6)
    fig1, ax1 = plt.subplots(figsize=(5.2, 5.0))
    ax1.plot(ex, ey, linewidth=1.8)
    ax1.axhline(0.0, linewidth=0.8)
    ax1.axvline(0.0, linewidth=0.8)
    ax1.set_xlabel(r"$E_x$")
    ax1.set_ylabel(r"$E_y$")
    ax1.set_title(f"Polarization trajectory: {label}")
    ax1.set_aspect("equal", adjustable="box")
    ax1.set_xlim(-1.15 * max_a, 1.15 * max_a)
    ax1.set_ylim(-1.15 * max_a, 1.15 * max_a)
    ax1.tick_params(direction="in", top=True, right=True)
    ax1.text(0.03, 0.97, "\n".join([f"State: {label}", f"Handedness: {handed}", rf"$\psi$ = {psi:.1f}°", rf"$\chi$ = {chi:.1f}°", rf"$s_1,s_2,s_3$ = ({s1:.2f}, {s2:.2f}, {s3:.2f})"]), transform=ax1.transAxes, va="top", fontsize=9)
    fig1.tight_layout()
    fig2, ax2 = plt.subplots(figsize=(7.0, 4.2))
    ax2.plot(phi, ex, linewidth=1.5, label=r"$E_x(t)$")
    ax2.plot(phi, ey, linewidth=1.5, label=r"$E_y(t)$")
    ax2.axhline(0.0, linewidth=0.8)
    ax2.set_xlabel(r"Phase / time variable $\phi$")
    ax2.set_ylabel("Field amplitude (a.u.)")
    ax2.set_title("Orthogonal sinusoidal components")
    ax2.legend(frameon=False)
    ax2.tick_params(direction="in", top=True, right=True)
    fig2.tight_layout()
    if save_prefix is not None:
        save_prefix.parent.mkdir(parents=True, exist_ok=True)
        fig1.savefig(save_prefix.with_name(save_prefix.name + "_front.png"), dpi=220)
        fig2.savefig(save_prefix.with_name(save_prefix.name + "_time.png"), dpi=220)
    if show:
        plt.show()
    else:
        plt.close(fig1)
        plt.close(fig2)

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Generate polarization-of-light plots from two orthogonal sinusoids.")
    parser.add_argument("--ax", type=float, default=1.0, help="Amplitude of Ex.")
    parser.add_argument("--ay", type=float, default=1.0, help="Amplitude of Ey.")
    parser.add_argument("--phase", type=float, default=90.0, help="Phase difference in degrees.")
    parser.add_argument("--save-prefix", type=Path, help="Optional figure prefix, e.g. figures/state.")
    parser.add_argument("--show", action="store_true", help="Show plots interactively.")
    return parser

def main() -> None:
    args = build_parser().parse_args()
    make_plots(ax=args.ax, ay=args.ay, phase_deg=args.phase, save_prefix=args.save_prefix, show=args.show)

if __name__ == "__main__":
    main()
