    <section class="info-grid">
      <article class="panel">
        <h2>Mathematical model</h2>
        <p>The electric field is decomposed into two orthogonal harmonic components with the same optical frequency:</p>
        <div class="equation">E<sub>x</sub>(t,z) = A<sub>x</sub> cos(kz − ωt),<br>E<sub>y</sub>(t,z) = A<sub>y</sub> cos(kz − ωt + δ)</div>
        <p>For polarization, the key free parameters are the amplitude ratio A<sub>y</sub>/A<sub>x</sub> and the phase difference δ.</p>
        <p>The normalized Stokes parameters for these ideal components are:</p>
        <div class="equation">s<sub>1</sub> = (A<sub>x</sub><sup>2</sup> − A<sub>y</sub><sup>2</sup>) / S<sub>0</sub><br>s<sub>2</sub> = 2A<sub>x</sub>A<sub>y</sub> cosδ / S<sub>0</sub><br>s<sub>3</sub> = 2A<sub>x</sub>A<sub>y</sub> sinδ / S<sub>0</sub></div>
      </article>

      <article class="panel">
        <h2>How to interpret the views</h2>
        <ul>
          <li><strong>Face view (xy):</strong> directly shows the polarization ellipse traced by the electric-field tip.</li>
          <li><strong>Side view (xz):</strong> shows the x-component of the field as the wave propagates along z.</li>
          <li><strong>Top view (yz):</strong> shows the y-component of the field along the same propagation axis.</li>
          <li><strong>Waveform plot:</strong> compares E<sub>x</sub>(t) and E<sub>y</sub>(t) in time.</li>
        </ul>
        <div class="callout">Pure polarization states require the two components to oscillate at the same frequency. The simulator therefore keeps a common frequency and lets you vary amplitudes and relative phase.</div>
      </article>

      <article class="panel">
        <h2>Suggested experiments</h2>
        <ul>
          <li>Set δ = 0° and compare Ax ≠ Ay versus Ax = Ay.</li>
          <li>Set Ax = Ay and vary δ from 0° to 90° to see linear → elliptical → circular polarization.</li>
          <li>Flip δ from +90° to −90° to reverse the handedness.</li>
          <li>Use the preset buttons and compare the Stokes parameters.</li>
          <li>Try Ax = 1 and Ay = 0.4 at δ = 60° to create a generic elliptical state.</li>
        </ul>
      </article>

      <article class="panel">
        <h2>Classification rules used here</h2>
        <ul>
          <li><strong>Linear:</strong> |sinδ| ≈ 0 or one amplitude vanishes.</li>
          <li><strong>Circular:</strong> Ax ≈ Ay and |δ| ≈ 90°.</li>
          <li><strong>Elliptical:</strong> all other non-degenerate cases.</li>
        </ul>
        <p>The orientation angle ψ and ellipticity angle χ are computed from the Stokes parameters.</p>
      </article>
    </section>
  </main>

  <footer><div class="container">Built as an open educational polarization repository by Deepak Kararwal. Released under the MIT License.</div></footer>

  <script>
    "use strict";
    const defaults = { ax: 1.00, ay: 1.00, phase: 90, wavelength: 4.0, speed: 1.0, trace: 1.0 };
    const controls = {};
    const valueLabels = {};
    for (const key of Object.keys(defaults)) {
      controls[key] = document.getElementById(key);
      valueLabels[key] = document.getElementById(key + "Value");
    }
    const frontCanvas = document.getElementById("frontCanvas");
    const sideCanvas = document.getElementById("sideCanvas");
    const topCanvas = document.getElementById("topCanvas");
    const timeCanvas = document.getElementById("timeCanvas");
    let playing = true;
    let phaseTime = 0;
    let lastStamp = 0;

    function readParams() {
      return {
        ax: Number(controls.ax.value),
        ay: Number(controls.ay.value),
        deltaDeg: Number(controls.phase.value),
        deltaRad: Number(controls.phase.value) * Math.PI / 180,
        wavelength: Number(controls.wavelength.value),
        speed: Number(controls.speed.value),
        trace: Number(controls.trace.value)
      };
    }
    function formatLabels() {
      const p = readParams();
      valueLabels.ax.textContent = p.ax.toFixed(2);
      valueLabels.ay.textContent = p.ay.toFixed(2);
      valueLabels.phase.textContent = p.deltaDeg.toFixed(0) + "°";
      valueLabels.wavelength.textContent = p.wavelength.toFixed(1) + " units";
      valueLabels.speed.textContent = p.speed.toFixed(2) + "×";
      valueLabels.trace.textContent = p.trace.toFixed(2);
    }
    function computeState() {
      const p = readParams();
      const S0 = p.ax * p.ax + p.ay * p.ay;
      const S1 = p.ax * p.ax - p.ay * p.ay;
      const S2 = 2 * p.ax * p.ay * Math.cos(p.deltaRad);
      const S3 = 2 * p.ax * p.ay * Math.sin(p.deltaRad);
      const s1 = S0 > 1e-12 ? S1 / S0 : 0;
      const s2 = S0 > 1e-12 ? S2 / S0 : 0;
      const s3 = S0 > 1e-12 ? S3 / S0 : 0;
      const psi = 0.5 * Math.atan2(S2, S1) * 180 / Math.PI;
      const chi = 0.5 * Math.asin(Math.max(-1, Math.min(1, s3))) * 180 / Math.PI;
      let label = "Zero field";
      let handed = "—";
      const eps = 0.045;
      if (S0 > 1e-10) {
        const equalAmp = Math.abs(p.ax - p.ay) < 0.04;
        const nearQuarter = Math.abs(Math.abs(p.deltaDeg) - 90) < 4;
        const nearLinear = Math.abs(Math.sin(p.deltaRad)) < eps || p.ax < 0.02 || p.ay < 0.02;
        if (nearLinear) { label = "Linear"; handed = "None"; }
        else if (equalAmp && nearQuarter) { label = "Circular"; handed = s3 > 0 ? "Left-handed" : "Right-handed"; }
        else { label = "Elliptical"; handed = s3 > 0 ? "Left-handed" : "Right-handed"; }
      }
      return { ...p, S0, s1, s2, s3, psi, chi, label, handed };
    }
    function updateMetrics() {
      const s = computeState();
      document.getElementById("stateMetric").textContent = s.label;
      document.getElementById("psiMetric").textContent = s.psi.toFixed(1) + "°";
      document.getElementById("chiMetric").textContent = s.chi.toFixed(1) + "°";
      document.getElementById("stokesMetric").textContent = `${s.s1.toFixed(2)}, ${s.s2.toFixed(2)}, ${s.s3.toFixed(2)}`;
      document.getElementById("handMetric").textContent = s.handed;
    }
    function canvasSetup(canvas) {
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      const width = Math.max(280, rect.width);
      const height = Math.max(220, rect.height);
      canvas.width = Math.round(width * dpr);
      canvas.height = Math.round(height * dpr);
      const ctx = canvas.getContext("2d");
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      return { ctx, width, height };
    }
    function clearAndBorder(ctx, width, height) {
      ctx.clearRect(0, 0, width, height);
      ctx.fillStyle = "rgba(3,12,22,0.72)";
      ctx.fillRect(0, 0, width, height);
    }
    function drawGrid(ctx, x0, y0, w, h, nX=8, nY=8) {
      ctx.strokeStyle = "rgba(190,210,235,0.14)";
      ctx.lineWidth = 1;
      for (let i = 0; i <= nX; i++) { const x = x0 + i * w / nX; ctx.beginPath(); ctx.moveTo(x, y0); ctx.lineTo(x, y0 + h); ctx.stroke(); }
      for (let j = 0; j <= nY; j++) { const y = y0 + j * h / nY; ctx.beginPath(); ctx.moveTo(x0, y); ctx.lineTo(x0 + w, y); ctx.stroke(); }
    }
    function drawFrontView() {
      const { ctx, width, height } = canvasSetup(frontCanvas);
      clearAndBorder(ctx, width, height);
      const pad = 24;
      drawGrid(ctx, pad, pad, width - 2 * pad, height - 2 * pad, 8, 8);
      const s = computeState();
      const centerX = width / 2, centerY = height / 2;
      const maxA = Math.max(s.ax, s.ay, 1e-6);
      const scale = 0.37 * Math.min(width, height) / maxA;
      ctx.strokeStyle = "rgba(220,236,255,0.42)";
      ctx.lineWidth = 1.4;
      ctx.beginPath(); ctx.moveTo(pad, centerY); ctx.lineTo(width - pad, centerY); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(centerX, pad); ctx.lineTo(centerX, height - pad); ctx.stroke();
      ctx.fillStyle = "#b7c7d9"; ctx.font = "12px system-ui, sans-serif";
      ctx.fillText("x", width - pad - 8, centerY - 8); ctx.fillText("y", centerX + 8, pad + 14);
      const samples = 360;
      ctx.strokeStyle = "rgba(56,189,248,0.92)";
      ctx.lineWidth = 2.2;
      ctx.beginPath();
      for (let i = 0; i <= samples; i++) {
        const phi = 2 * Math.PI * i / samples;
        const ex = s.ax * Math.cos(phi);
        const ey = s.ay * Math.cos(phi + s.deltaRad);
        const px = centerX + ex * scale, py = centerY - ey * scale;
        if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
      }
      ctx.stroke();
      const exNow = s.ax * Math.cos(phaseTime);
      const eyNow = s.ay * Math.cos(phaseTime + s.deltaRad);
      const px = centerX + exNow * scale, py = centerY - eyNow * scale;
      ctx.strokeStyle = "rgba(245,158,11,0.90)";
      ctx.lineWidth = 1.8;
      ctx.beginPath(); ctx.moveTo(centerX, centerY); ctx.lineTo(px, py); ctx.stroke();
      ctx.fillStyle = "#f59e0b";
      ctx.beginPath(); ctx.arc(px, py, 5.2, 0, 2 * Math.PI); ctx.fill();
      const trailCount = Math.floor(120 * s.trace);
      if (trailCount > 1) {
        for (let j = 1; j <= trailCount; j++) {
          const frac = j / trailCount;
          const phi = phaseTime - frac * Math.PI * 1.5;
          const ex = s.ax * Math.cos(phi), ey = s.ay * Math.cos(phi + s.deltaRad);
          ctx.fillStyle = `rgba(167,139,250,${0.35 * (1 - frac)})`;
          ctx.beginPath(); ctx.arc(centerX + ex * scale, centerY - ey * scale, 2.2, 0, 2 * Math.PI); ctx.fill();
        }
      }
      ctx.strokeStyle = "rgba(220,236,255,0.35)";
      ctx.strokeRect(pad, pad, width - 2 * pad, height - 2 * pad);
    }
    function drawWaveProjection(canvas, component="x") {
      const { ctx, width, height } = canvasSetup(canvas);
      clearAndBorder(ctx, width, height);
      const s = computeState();
      const margin = { left: 46, right: 18, top: 20, bottom: 34 };
      const plotW = width - margin.left - margin.right;
      const plotH = height - margin.top - margin.bottom;
      drawGrid(ctx, margin.left, margin.top, plotW, plotH, 8, 8);
      const amp = component === "x" ? s.ax : s.ay;
      const localPhase = component === "x" ? 0 : s.deltaRad;
      const zMin = 0, zMax = 2.0 * s.wavelength;
      const maxA = Math.max(s.ax, s.ay, 1e-6) * 1.1;
      const xToPx = z => margin.left + (z - zMin) / (zMax - zMin) * plotW;
      const yToPx = v => margin.top + (maxA - v) / (2 * maxA) * plotH;
      ctx.strokeStyle = "rgba(220,236,255,0.42)";
      ctx.lineWidth = 1.4;
      ctx.beginPath(); ctx.moveTo(margin.left, yToPx(0)); ctx.lineTo(margin.left + plotW, yToPx(0)); ctx.stroke();
      ctx.fillStyle = "#b7c7d9"; ctx.font = "12px system-ui, sans-serif";
      ctx.fillText("z", margin.left + plotW - 8, yToPx(0) - 8); ctx.fillText(component, margin.left + 4, margin.top + 12);
      const k = 2 * Math.PI / s.wavelength;
      const points = 500;
      ctx.strokeStyle = component === "x" ? "#34d399" : "#fb7185";
      ctx.lineWidth = 2.1;
      ctx.beginPath();
      for (let i = 0; i <= points; i++) {
        const z = zMin + (zMax - zMin) * i / points;
        const v = amp * Math.cos(k * z - phaseTime + localPhase);
        const px = xToPx(z), py = yToPx(v);
        if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
      }
      ctx.stroke();
      const zMarker = 0.45 * s.wavelength;
      const vMarker = amp * Math.cos(k * zMarker - phaseTime + localPhase);
      ctx.fillStyle = "#f59e0b";
      ctx.beginPath(); ctx.arc(xToPx(zMarker), yToPx(vMarker), 5.0, 0, 2 * Math.PI); ctx.fill();
      ctx.strokeStyle = "rgba(220,236,255,0.35)";
      ctx.strokeRect(margin.left, margin.top, plotW, plotH);
    }
    function niceTicks(min, max, count=6) {
      const span = Math.max(max - min, 1e-12), raw = span / count;
      const pow = 10 ** Math.floor(Math.log10(raw)), mult = raw / pow;
      const step = (mult < 1.5 ? 1 : mult < 3 ? 2 : mult < 7 ? 5 : 10) * pow;
      const start = Math.ceil(min / step) * step;
      const ticks = [];
      for (let v = start; v <= max + 0.25 * step; v += step) ticks.push(v);
      return ticks;
    }
    function drawTimeTraces() {
      const { ctx, width, height } = canvasSetup(timeCanvas);
      clearAndBorder(ctx, width, height);
      const s = computeState();
      const margin = { left: 58, right: 18, top: 18, bottom: 44 };
      const plotW = width - margin.left - margin.right;
      const plotH = height - margin.top - margin.bottom;
      drawGrid(ctx, margin.left, margin.top, plotW, plotH, 8, 8);
      const tMin = 0, tMax = 2 * Math.PI;
      const yMin = -Math.max(s.ax, s.ay, 1e-6) * 1.15;
      const yMax = -yMin;
      const xToPx = t => margin.left + (t - tMin) / (tMax - tMin) * plotW;
      const yToPx = y => margin.top + (yMax - y) / (yMax - yMin) * plotH;
      ctx.strokeStyle = "rgba(220,236,255,0.42)";
      ctx.lineWidth = 1.4;
      ctx.beginPath(); ctx.moveTo(margin.left, yToPx(0)); ctx.lineTo(margin.left + plotW, yToPx(0)); ctx.stroke();
      ctx.fillStyle = "#9eb1c8"; ctx.font = "12px system-ui, sans-serif";
      for (const tick of niceTicks(0, 2 * Math.PI, 6)) {
        const x = xToPx(tick);
        ctx.strokeStyle = "rgba(190,210,235,0.16)";
        ctx.beginPath(); ctx.moveTo(x, margin.top); ctx.lineTo(x, margin.top + plotH); ctx.stroke();
        ctx.fillText((tick / Math.PI).toFixed(1) + "π", x - 10, margin.top + plotH + 18);
      }
      for (const tick of niceTicks(yMin, yMax, 5)) {
        const y = yToPx(tick);
        ctx.fillText(tick.toFixed(1), margin.left - 38, y + 4);
      }
      function drawCurve(color, fn) {
        ctx.strokeStyle = color; ctx.lineWidth = 2.2; ctx.beginPath();
        const points = 500;
        for (let i = 0; i <= points; i++) {
          const t = tMin + (tMax - tMin) * i / points;
          const px = xToPx(t), py = yToPx(fn(t));
          if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
        }
        ctx.stroke();
      }
      drawCurve("#34d399", t => s.ax * Math.cos(t));
      drawCurve("#fb7185", t => s.ay * Math.cos(t + s.deltaRad));
      const markerT = ((phaseTime % (2 * Math.PI)) + 2 * Math.PI) % (2 * Math.PI);
      const exM = s.ax * Math.cos(markerT), eyM = s.ay * Math.cos(markerT + s.deltaRad);
      ctx.fillStyle = "#34d399"; ctx.beginPath(); ctx.arc(xToPx(markerT), yToPx(exM), 4.8, 0, 2 * Math.PI); ctx.fill();
      ctx.fillStyle = "#fb7185"; ctx.beginPath(); ctx.arc(xToPx(markerT), yToPx(eyM), 4.8, 0, 2 * Math.PI); ctx.fill();
      ctx.fillStyle = "#b7c7d9"; ctx.fillText("time / phase", margin.left + plotW / 2 - 28, height - 9);
      ctx.fillStyle = "#34d399"; ctx.fillText("Ex(t)", margin.left + 10, margin.top + 16);
      ctx.fillStyle = "#fb7185"; ctx.fillText("Ey(t)", margin.left + 70, margin.top + 16);
      ctx.strokeStyle = "rgba(220,236,255,0.35)";
      ctx.strokeRect(margin.left, margin.top, plotW, plotH);
    }
    function renderAll() { formatLabels(); updateMetrics(); drawFrontView(); drawWaveProjection(sideCanvas, "x"); drawWaveProjection(topCanvas, "y"); drawTimeTraces(); }
    function applyPreset(name) {
      const presetMap = {
        "linear-x": { ax: 1.0, ay: 0.0, phase: 0 },
        "linear-y": { ax: 0.0, ay: 1.0, phase: 0 },
        "linear-45": { ax: 1.0, ay: 1.0, phase: 0 },
        "linear-135": { ax: 1.0, ay: 1.0, phase: 180 },
        "circular-r": { ax: 1.0, ay: 1.0, phase: -90 },
        "circular-l": { ax: 1.0, ay: 1.0, phase: 90 },
        "elliptical-r": { ax: 1.0, ay: 0.65, phase: -60 },
        "elliptical-l": { ax: 1.0, ay: 0.65, phase: 60 }
      };
      const p = presetMap[name]; if (!p) return;
      controls.ax.value = p.ax.toFixed(2); controls.ay.value = p.ay.toFixed(2); controls.phase.value = String(p.phase); renderAll();
    }
    for (const key of Object.keys(defaults)) controls[key].addEventListener("input", renderAll);
    document.querySelectorAll("[data-preset]").forEach(btn => btn.addEventListener("click", () => applyPreset(btn.dataset.preset)));
    document.getElementById("resetBtn").addEventListener("click", () => { for (const key of Object.keys(defaults)) controls[key].value = defaults[key]; renderAll(); });
    document.getElementById("playBtn").addEventListener("click", (e) => { playing = !playing; e.target.textContent = playing ? "Pause animation" : "Play animation"; });
    function animate(stamp) {
      if (!lastStamp) lastStamp = stamp;
      const dt = (stamp - lastStamp) / 1000;
      lastStamp = stamp;
      if (playing) { phaseTime += dt * 2.5 * readParams().speed; renderAll(); }
      requestAnimationFrame(animate);
    }
    window.addEventListener("resize", renderAll);
    renderAll();
    requestAnimationFrame(animate);
  </script>
</body>
</html>
